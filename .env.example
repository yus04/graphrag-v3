# --- API credentials ---
GRAPHRAG_API_KEY=
GRAPHRAG_API_BASE=https://<your-resource>.services.ai.azure.com

# --- Completion model ---
GRAPHRAG_COMPLETION_MODEL=gpt-4.1
GRAPHRAG_COMPLETION_DEPLOYMENT_NAME=gpt-4.1

# --- Embedding model ---
GRAPHRAG_EMBEDDING_MODEL=text-embedding-3-large
GRAPHRAG_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# --- Local storage paths ---
GRAPHRAG_INPUT_BASE_DIR=input
GRAPHRAG_OUTPUT_BASE_DIR=output
GRAPHRAG_LOGS_BASE_DIR=logs
GRAPHRAG_CACHE_BASE_DIR=cache
GRAPHRAG_LANCEDB_URI=output/lancedb

# --- Azure Blob Storage (Azure環境のみ) ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
GRAPHRAG_BLOB_CONTAINER_INPUT=graphrag-input
GRAPHRAG_BLOB_CONTAINER_OUTPUT=graphrag-output
GRAPHRAG_BLOB_CONTAINER_LOGS=graphrag-logs
GRAPHRAG_BLOB_CONTAINER_CACHE=graphrag-cache

# --- Azure CosmosDB (Azure環境のみ) ---
COSMOSDB_CONNECTION_STRING=
COSMOSDB_URL=https://<your-account>.documents.azure.com
GRAPHRAG_COSMOSDB_DATABASE=graphrag

# --- Azure AI Search (Azure環境のみ) ---
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_URL=https://<your-search-service>.search.windows.net
AZURE_SEARCH_AUDIENCE=https://search.azure.com
